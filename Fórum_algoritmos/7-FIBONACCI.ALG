Algoritmo "Fibonacci"

Var

  N, i, a, b, proximo: inteiro

Inicio

   escreva("atÕ qual termo vocõ quer na sequõncia de Fibonacci?: ")
   leia(N)

   a <- 1
   b <- 1
   enquanto i < N faca
   
     escreva(a,"")

     proximo <- a + b
     
     a <- b
     b <- proximo
     i <- i + 1

   fimenquanto

   escreval()
   
Fimalgoritmo