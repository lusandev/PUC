Algoritmo "desconto_15"

Var

 valor_produto, desconto: real

Inicio

    escreva("Valor do produto: ")
    leia(valor_produto)
    escreval()
    
    desconto <- valor_produto * 0.85
    
    escreva("Prešo final com 15% de desconto: ", desconto, "R$")
    escreval()
    
Fimalgoritmo