Algoritmo "temperatura"

Var

  F,C: real

Inicio

   Escreva("Digite a temperatura em Fahrenheit: ")
   leia(F)
   
   C <- (F - 32) * 5/9
   
   escreval()
   escreval("Temperatura em Fahrenheit: ", F, "°F")

   escreval()
   escreval("temperatura em Celsius: ", C:4:2 , "°C")

Fimalgoritmo